# ============================================
# Vite 本地文件存储插件（filesStoragePlugin）配置
# ============================================
#
# FILES_DIR —— 指定本地文件保存根目录（相对于 Vite 项目根）
# 默认：docs/files
# 示例：
#   FILES_DIR=docs/files              # 默认值，保存到 ./docs/files/
#   FILES_DIR=/tmp/ai-vido-files      # 自定义绝对路径（开发环境测试用）
#   FILES_DIR=$HOME/Downloads/ai-vido # 跨平台写法
#
# 注意：
#   - 路径必须可写，插件启动时会 mkdirSync({ recursive: true })
#   - 必须是相对 Vite 项目根的相对路径或绝对路径
#   - 修改后需要重启 Vite dev server
FILES_DIR=docs/files

# ============================================
# FILES_MAX_SIZE_MB —— 单次上传最大字节数（MB）
# 默认：50
# 用途：防止恶意请求把磁盘写满
# 注意：超出限制会返回 HTTP 413 与 code: PAYLOAD_TOO_LARGE
#       大文件场景（如视频后期合成）建议调大到 200+
# ============================================
# FILES_MAX_SIZE_MB=50